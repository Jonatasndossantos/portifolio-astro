---
import { getCollection } from "astro:content";
import { locales, useTranslator } from "@i18n";
import Layout from "@layouts/Layout.astro";

// Generate paths for standard locales
export async function getStaticPaths() {
    return locales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: string };
const __ = await useTranslator(locale);

// Fetch all blog posts
const allPosts = await getCollection("blog");

// Filter out drafts
const publishedPosts = allPosts.filter((post) => !post.data.draft);

// Group posts by slug (so we don't show duplicates if both pt and en exist)
type PostMap = { [slug: string]: any };
const postsMap: PostMap = {};

for (const post of publishedPosts) {
    // The id from glob loader looks like 'pt/my-post' or 'en/my-post'
    const parts = post.id.split('/');
    if (parts.length < 2) continue;
    
    const postLang = parts[0]; // 'pt' or 'en'
    // Remove the extension from the slug to avoid URLs like /en/blog/my-post.md
    const postSlug = parts.slice(1).join('/').replace(/\.mdx?$/, "");

    // If we haven't seen this slug yet, add it
    if (!postsMap[postSlug]) {
        postsMap[postSlug] = post;
    } else {
        // If we already have it, overwite ONLY IF this new one matches the current locale
        // This ensures EN users see the EN post if available, but PT otherwise.
        if (postLang === locale) {
            postsMap[postSlug] = post;
        }
    }
}

// Convert map back to array and sort by date descending
const posts = Object.entries(postsMap).map(([slug, post]) => {
    return {
        slug,
        ...post
    }
}).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout
    title={__("Blog")}
    description={__("Multilingual blog")}
    lang={locale}
>
    <main class="w-full min-h-screen bg-base-100 pt-32 pb-20 px-6 lg:px-20 relative">
        <div class="max-w-4xl mx-auto z-10 relative">
            <h1 class="text-4xl md:text-5xl font-bold font-syncopate mb-12">
                {__("Blog")}
            </h1>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {posts.map((post) => (
                    <a 
                        href={`/${locale}/blog/${post.slug}`}
                        class="card bg-base-200/50 hover:bg-base-200 transition-colors border border-base-content/5 group"
                    >
                        <div class="card-body">
                            <h2 class="card-title text-2xl group-hover:text-primary transition-colors">
                                {post.data.title}
                            </h2>
                            <p class="text-sm opacity-60 mb-4">
                                {new Date(post.data.date).toLocaleDateString(locale, {
                                    year: 'numeric',
                                    month: 'long',
                                    day: 'numeric'
                                })}
                            </p>
                            <div class="card-actions justify-end mt-auto">
                                <span class="bg-primary text-primary-content text-xs font-bold px-3 py-1 rounded-full group-hover:-translate-y-1 transition-transform">
                                    {__("Read more")} &rarr;
                                </span>
                            </div>
                        </div>
                    </a>
                ))}
            </div>
        </div>
    </main>
</Layout>
