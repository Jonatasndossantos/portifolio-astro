---
import { getCollection, render } from "astro:content";
import { locales } from "@i18n";
import Layout from "@layouts/Layout.astro";
import GraphIsland from "@components/GraphIsland.astro";

export async function getStaticPaths() {
    const services = await getCollection("services");

    return locales.flatMap((locale) =>
        services.map((service) => {
            const cleanId = service.id.replace(/\.mdx?$/, "");
            return {
                params: { locale, slug: cleanId },
                props: { locale, service, cleanId },
            };
        }),
    );
}

const { locale } = Astro.params;
const { service, cleanId } = Astro.props;

// Find all content that references this service
const allProjects = await getCollection("projects");
const allBlogs = await getCollection("blog");

const relatedProjects = allProjects.filter((p) =>
    p.data.relatedServices?.some((ref: any) => {
        const refId = typeof ref === 'string' ? ref : ref.id;
        return refId.replace(/\.mdx?$/, "") === cleanId;
    }),
);

// ctaService is a single reference, not an array
const relatedBlogs = allBlogs.filter((b) => {
    if (!b.data.ctaService) return false;
    const ctaId = typeof b.data.ctaService === 'string' ? b.data.ctaService : (b.data.ctaService as any).id;
    return ctaId.replace(/\.mdx?$/, "") === cleanId;
});

const { Content } = await render(service);
---

<Layout
    title={`${service.data.title} | Services`}
    description={`Service details for ${service.data.title}`}
    lang={locale}
>
    <main
        class="w-full min-h-screen bg-base-100 pt-32 pb-20 px-6 lg:px-20 relative overflow-hidden"
    >
        <div class="max-w-4xl mx-auto relative z-10">
            <a
                href={`/${locale}/services`}
                class="btn btn-ghost btn-sm mb-8 opacity-70 hover:opacity-100 uppercase tracking-widest text-xs"
            >
                &larr; Back to Services
            </a>

            <div class="flex flex-col md:flex-row md:items-center gap-6 mb-8 justify-between">
                <div class="flex items-center gap-6">
                    {
                        service.data.icon ? (
                            <div class="w-16 h-16 rounded bg-base-200 flex items-center justify-center text-3xl">
                                {service.data.icon}
                            </div>
                        ) : (
                            <div class="w-16 h-16 rounded bg-base-200 flex items-center justify-center text-3xl font-bold">
                                💼
                            </div>
                        )
                    }
                    <div>
                        <span
                            class="badge badge-primary badge-outline uppercase tracking-wider text-xs mb-2"
                        >
                            Service
                        </span>
                        <h1 class="text-4xl md:text-5xl font-bold font-syncopate">
                            {service.data.title}
                        </h1>
                    </div>
                </div>
                {service.data.priceStartingAt && (
                    <div class="text-left md:text-right mt-4 md:mt-0 p-4 bg-base-200 rounded-xl border border-base-content/10">
                        <div class="text-sm opacity-70 uppercase tracking-wider mb-1">Starting At</div>
                        <div class="text-3xl font-bold text-primary">${service.data.priceStartingAt}</div>
                    </div>
                )}
            </div>

            <article
                class="prose prose-lg prose-invert mb-16 max-w-none prose-p:text-base-content/70"
            >
                <Content />
            </article>

            <div class="mb-16">
                <h2
                    class="text-2xl font-bold mb-6 border-b border-base-content/10 pb-4"
                >
                    Knowledge Graph
                </h2>
                <GraphIsland focusId={`services/${cleanId}`} />
            </div>

            {
                relatedProjects.length > 0 && (
                    <div class="mb-12">
                        <h2 class="text-2xl font-bold mb-6 border-b border-base-content/10 pb-4">
                            Projects using this Service
                        </h2>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            {relatedProjects.map((p) => (
                                <a
                                    href={`/${locale}/projects/${p.id.replace(/\.mdx?$/, "")}`}
                                    class="card bg-base-200/50 hover:bg-base-200 transition-colors border border-base-content/5"
                                >
                                    <div class="card-body p-6">
                                        <h3 class="card-title text-lg">
                                            {p.data.title}
                                        </h3>
                                        <p class="text-sm opacity-70 line-clamp-2">
                                            View Case Study &rarr;
                                        </p>
                                    </div>
                                </a>
                            ))}
                        </div>
                    </div>
                )
            }

            {
                relatedBlogs.length > 0 && (
                    <div class="mb-12">
                        <h2 class="text-2xl font-bold mb-6 border-b border-base-content/10 pb-4">
                            Related Articles
                        </h2>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            {relatedBlogs.map((b) => (
                                <a
                                    href={`/${locale}/blog/${b.id.replace(/\.mdx?$/, "")}`}
                                    class="card bg-base-200/50 hover:bg-base-200 transition-colors border border-base-content/5"
                                >
                                    <div class="card-body p-6">
                                        <h3 class="card-title text-lg">
                                            {b.data.title}
                                        </h3>
                                    </div>
                                </a>
                            ))}
                        </div>
                    </div>
                )
            }
        </div>
    </main>
</Layout>
