---
import Layout from "@layouts/Layout.astro";
import Hero from "@islands/Hero.astro";
import About from "@components/sections/About.astro";
import Skills from "@components/sections/Skills.astro";
import Projects from "@components/sections/Projects.astro";
import Services from "@components/sections/Services.astro";
import Contact from "@components/sections/Contact.astro";
import Footer from "@components/layout/Footer.astro";
import GraphIsland from "@components/GraphIsland.astro";
import { Mode } from "../../../types";
import { getTranslations, locales } from "@i18n";
import { getRelativeLocaleUrl } from "astro:i18n";
import type { CuratedProfile } from "../../../types";

export function getStaticPaths() {
    return locales.map((locale) => ({
        params: { locale },
        props: { locale },
    }));
}

const { locale } = Astro.params;
const lang = getRelativeLocaleUrl(locale);

const profile = (await getTranslations(lang, "profile")) as Record<
    string,
    unknown
>;
const bio = (profile.bio as Record<string, string>)?.[Mode.FULLSTACK] ?? "";
const role = (profile.role as Record<string, string>)?.[Mode.FULLSTACK] ?? "";

const tPortfolio = (await getTranslations(lang, "portfolio")) as Record<
    string,
    any
>;

const profileData: CuratedProfile = {
    name: "Jônatas Nascimento dos Santos",
    role: role,
    bio: bio,
    availableForHire: true,
    socials: {
        github: "https://github.com/jonatasndossantos",
        linkedin: "https://linkedin.com/in/jonatasndossantos",
        email: "jonatasndossantos@gmail.com",
    },
};

// Pre-process skills for the current Mode
const currentSkills = (tPortfolio.skills.list as any[])
    .map((s) => ({
        ...s,
        currentRelevance: s.relevance?.[Mode.FULLSTACK] || 0,
    }))
    .sort((a, b) => b.currentRelevance - a.currentRelevance);

// Pre-process projects for the current language and Mode
const currentProjects = (tPortfolio.projects.list as any[]).map((p) => ({
    ...p,
    displayDescription:
        p.description?.[Mode.FULLSTACK] || p.description?.["fullstack"] || "",
}));
---

<Layout
    title="Fullstack"
    description={`${role} — ${bio.slice(0, 120)}...`}
    lang={locale}
>
    <main class="relative w-full overflow-hidden">
        <Hero mode={Mode.FULLSTACK} lang={locale} />
        <div class="relative z-10 bg-base-100">
            <About
                skills={currentSkills}
                profile={profileData}
                mode={Mode.FULLSTACK}
                lang={locale}
            />
            <Skills
                skills={currentSkills}
                mode={Mode.FULLSTACK}
                lang={locale}
            />

            <Projects projects={currentProjects} lang={locale} />

            <section
                class="w-full py-20 px-6 lg:px-20 bg-base-100 flex flex-col items-center"
            >
                <div class="max-w-7xl w-full">
                    <h2 class="text-3xl font-bold mb-4 font-syncopate">
                        Interactive <span class="text-primary"
                            >Knowledge Graph</span
                        >
                    </h2>
                    <p class="mb-10 opacity-70 max-w-2xl">
                        This is my entire Second Brain network plotted out. You
                        are seeing the actual `.mdx` nodes and their semantic
                        relationships (`topics`, `tags`, `services`). Try
                        zooming and dragging the nodes!
                    </p>
                    <GraphIsland />
                </div>
            </section>

            <Services lang={locale} />
            <Contact profile={profileData} lang={locale} />
            <Footer lang={locale} />
        </div>
    </main>
</Layout>
