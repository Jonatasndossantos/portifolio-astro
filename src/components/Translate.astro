---
import { getTranslations } from "@i18n";

interface Props {
    /** By using a flat key, we can search our nested dictionaries.
     * Example: "projects.gov-docs-ai.description.fullstack"
     */
    textKey: string;
    /** The language provided dynamically by Astro routing */
    lang?: string;
    /** Any variables to be injected into the string at runtime */
    vars?: Record<string, string | number>;
}

const { textKey, lang = "en", vars = {} } = Astro.props;

// A generic "global" object that imports from Intlayer
// (For this example, we'll try to use the raw `profile` or `portfolio` dicts.)
// If we create a separate namespace per project, we'd pass that instead.
const dict = (await getTranslations(lang, "portfolio")) as Record<string, any>;

/**
 * Access deeply nested values by string literal.
 * Ex: getNestedValue(dict, "projects.list.0.title")
 */
function getNestedValue(obj: any, path: string): string {
    return path.split(".").reduce((curr, key) => {
        // Handle array indices and object keys
        return curr && curr[key] !== undefined ? curr[key] : curr;
    }, obj) as string;
}

let translatedText = getNestedValue(dict, textKey);

// Basic variable replacement {{varName}}
if (translatedText && typeof translatedText === "string") {
    Object.keys(vars).forEach((vKey) => {
        const regex = new RegExp(`{{${vKey}}}`, "g");
        translatedText = translatedText.replace(regex, String(vars[vKey]));
    });
}

// Fallback to exactly the key string in development if not found
if (typeof translatedText !== "string") {
    translatedText = `[MISSING: ${textKey}]`;
}
---

<Fragment set:html={translatedText} />
