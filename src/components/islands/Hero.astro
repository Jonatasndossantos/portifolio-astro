---
import { Volume2, VolumeX } from "lucide-react";
import { getTranslations } from "@i18n";
import { Image } from "astro:assets";
import bgFallback from "../../assets/Underwater Transition@1-1920x919.png";

/**
 * Hero receives pre-resolved, locale+mode-aware strings from the Astro parent.
 * No i18n logic here — pure rendering.
 *
 * The Astro parent does:
 *   <Hero bio={profile.bio[mode]} role={profile.role[mode]} ... />
 */

const { lang, mode } = Astro.props;
const profile = (await getTranslations(lang, "profile")) as Record<string, any>;
---

<script>
    import { Application } from "@splinetool/runtime";

    const canvas = document.getElementById("canvas3d") as HTMLCanvasElement;
    const muteBtn = document.getElementById("mute-btn");
    const iconMute = document.getElementById("icon-mute");
    const iconVol = document.getElementById("icon-vol");

    if (canvas) {
        let app: Application | null = null;
        let isLoaded = false;
        let isMuted = true;

        const initSpline = () => {
            if (isLoaded) return;
            isLoaded = true;
            app = new Application(canvas);
            app.load(
                "https://prod.spline.design/LemjWKcGZtc47q1C/scene.splinecode",
            ).then(() => {
                canvas.classList.remove("opacity-0");
                const fallback = document.getElementById("spline-fallback");
                if (fallback) fallback.classList.add("opacity-0");

                try {
                    if (typeof (app as any).setVolume === "function")
                        (app as any).setVolume(isMuted ? 0 : 1);
                } catch (e) {
                    console.warn("Spline Volume Init Error:", e);
                }
            });
        };

        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        if (!isLoaded) {
                            // Delay loading slightly so it doesn't block LCP
                            setTimeout(initSpline, 500);
                        } else if (app) {
                            try {
                                if (typeof (app as any).play === "function")
                                    (app as any).play();
                            } catch (e) {
                                console.warn("Spline Play Error:", e);
                            }
                        }
                    } else {
                        if (app) {
                            try {
                                if (typeof (app as any).stop === "function")
                                    (app as any).stop();
                            } catch (e) {
                                console.warn("Spline Stop Error:", e);
                            }
                        }
                    }
                });
            },
            { threshold: 0 },
        );

        observer.observe(canvas);

        if (muteBtn) {
            // Ensure audio handles browser policies correctly via user click.
            muteBtn.addEventListener("click", () => {
                isMuted = !isMuted;

                if (isMuted) {
                    iconMute?.classList.remove("hidden");
                    iconVol?.classList.add("hidden");
                } else {
                    iconMute?.classList.add("hidden");
                    iconVol?.classList.remove("hidden");
                }

                if (app) {
                    try {
                        if (typeof (app as any).setVolume === "function")
                            (app as any).setVolume(isMuted ? 0 : 1);
                    } catch (e) {
                        console.warn("Spline Audio Error:", e);
                    }
                }
            });
        }
    }
</script>

<section
    class="relative min-h-screen w-full flex flex-col justify-center px-6 lg:px-20 overflow-hidden pt-32 pb-20"
>
    <div class="absolute inset-0 z-0 opacity-60 hero-parallax">
        <Image
            id="spline-fallback"
            src={bgFallback}
            alt="Hero Background"
            class="absolute inset-0 w-full h-full object-cover z-0 transition-opacity duration-1000"
            loading="eager"
            fetchpriority="high"
        />
        <canvas
            id="canvas3d"
            class="absolute inset-0 w-full h-full border-0 z-10 transition-opacity duration-1000 opacity-0"
        ></canvas>

        <!-- Watermark Hider via Gradient -->
        <div
            class="absolute bottom-0 right-0 w-64 h-24 bg-gradient-to-tl from-base-300 via-base-300/60 to-transparent z-10 pointer-events-none"
        >
        </div>
    </div>

    <div
        class="absolute inset-0 bg-gradient-to-t from-base-300/90 via-base-300/40 to-transparent z-0 pointer-events-none"
    >
    </div>
    <div
        class="absolute inset-0 z-0 opacity-[0.03] pointer-events-none mix-blend-overlay"
        style={{
            backgroundImage:
                'url("https://grainy-gradients.vercel.app/noise.svg")',
        }}
    >
    </div>

    <header
        class="relative z-10 w-full max-w-4xl hero-parallax text-left flex flex-col justify-center"
    >
        <div class="overflow-hidden">
            <h1
                class="text-6xl md:text-8xl font-bold leading-tight tracking-tighter mb-2 text-balance break-keep"
                data-gsap="hero-title"
            >
                {profile.greeting}
            </h1>
        </div>

        <div class="overflow-hidden">
            <h2
                class="opacity-80 text-4xl md:text-5xl font-light mb-8 text-balance break-keep"
                data-gsap="hero-role"
            >
                {profile.modes[mode].role}
            </h2>
        </div>

        <div class="overflow-hidden">
            <div
                class="text-2xl md:text-3xl font-medium mb-8 flex flex-wrap gap-2 items-center"
                data-gsap="hero-rotating-text"
            >
                <span>{profile.providingSolutionsFor}</span>
                <span
                    class="text-rotate h-10 inline-block overflow-hidden align-bottom"
                >
                    <span class="flex flex-col text-left">
                        <span class="text-accent h-10">{profile.designers}</span
                        >
                        <span class="text-secondary h-10"
                            >{profile.developers}</span
                        >
                        <span class="text-primary h-10">{profile.managers}</span
                        >
                        <span class="text-accent h-10">{profile.designers}</span
                        >
                    </span>
                </span>
            </div>
        </div>

        <div class="overflow-hidden">
            <p
                class="text-lg md:text-xl max-w-xl leading-relaxed mb-10 text-pretty opacity-80 break-keep"
                data-gsap="hero-bio"
            >
                {profile.modes[mode].bio}
            </p>
        </div>
    </header>

    <div
        class="absolute bottom-10 right-10 hidden md:block animate-bounce z-10 pointer-events-none"
    >
        <div
            class="text-xs font-mono opacity-50 rotate-90 origin-bottom-right tracking-widest"
        >
            {profile.scroll}
        </div>
    </div>

    <!-- Audio Toggle Button -->
    <button
        id="mute-btn"
        type="button"
        class="btn btn-circle btn-ghost bg-base-100/30 backdrop-blur-md absolute bottom-10 left-6 md:left-20 z-10 group hover:bg-base-100/60 transition-all border border-base-content/10"
        aria-label="Toggle Spline Audio"
    >
        <div id="icon-mute">
            <VolumeX
                aria-hidden="true"
                className="size-5 text-base-content opacity-70"
            />
        </div>
        <div id="icon-vol" class="hidden">
            <Volume2
                aria-hidden="true"
                className="size-5 text-base-content opacity-70"
            />
        </div>
    </button>
</section>
