---
import { getTranslations, useTranslatedPath } from "@i18n";

interface Props {
    lang: string;
}

const { lang } = Astro.props;
const t = (await getTranslations(lang, "portfolio")) as Record<string, any>;
const translatePath = useTranslatedPath(lang);
const navRecord = (await getTranslations(lang, "nav")) as Record<
    string,
    string
>;
---

<footer
    class="footer footer-center p-10 bg-base-200 text-base-content rounded mt-auto border-t border-base-content/10 relative overflow-hidden"
>
    <div class="absolute inset-0 pointer-events-none flex justify-around">
        {
            Array.from({ length: 10 }).map(() => (
                <div
                    class="w-1 h-1 bg-primary rounded-full opacity-50 mt-20 animate-bounce"
                    style={`animation-delay: ${Math.random() * 2}s; animation-duration: ${2 + Math.random() * 2}s;`}
                />
            ))
        }
    </div>

    <aside
        class="relative z-10 w-full flex flex-col md:flex-row justify-between items-center max-w-7xl mx-auto"
    >
        <div class="mb-4 md:mb-0 text-center md:text-left">
            <h4 class="text-xl font-bold tracking-tight">JÔNATAS</h4>
            <p class="text-xs text-base-content/60">
                © {new Date().getFullYear()}
                {t.footer.copyright}
            </p>
        </div>

        <nav
            class="flex gap-8 text-xs font-mono text-base-content/70 flex-wrap justify-center"
        >
            <a
                href={translatePath("/")}
                class="hover:text-primary transition-colors"
                >{t.footer.links.home}</a
            >
            <a
                href={translatePath("/ecosystem")}
                class="hover:text-primary font-bold uppercase tracking-wider text-primary transition-colors"
                >{navRecord.ecosystem || "Ecosystem"}</a
            >
            <a href="#about" class="hover:text-primary transition-colors"
                >{t.footer.links.about}</a
            >
            <a href="#projects" class="hover:text-primary transition-colors"
                >{t.footer.links.work}</a
            >
            <a href="#contact" class="hover:text-primary transition-colors"
                >{t.footer.links.contact}</a
            >
        </nav>
    </aside>
</footer>
