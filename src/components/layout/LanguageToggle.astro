---
import { getRelativeLocaleUrl } from "astro:i18n";
import {
    locales,
    nativeNames,
    getPathWithoutLocale,
    defaultLocale,
} from "@i18n";
import { getTranslations, useTranslator } from "@i18n";
import { Icon } from "astro-icon/components";

interface Props {
    currentLocale?: string;
    class?: string;
}

const { currentLocale = defaultLocale, class: className } = Astro.props;

const currentPath = getPathWithoutLocale(Astro.url.pathname);

const langDict = (await getTranslations(currentLocale, "language")) as Record<
    string,
    string
>;
const __ = await useTranslator(currentLocale);
---

<div title={__("Change Language")} class:list={["dropdown dropdown-end sm:dropdown-bottom dropdown-top block", className]}>
    <div
        tabindex="0"
        role="button"
        class="btn group btn-sm gap-2 px-2 btn-ghost w-full justify-between sm:w-auto sm:justify-center"
        aria-label={__("Change Language")}
    >
        <div class="flex items-center gap-3">
            <div class="relative flex items-center justify-center pt-0.5">
                <Icon name="lucide:globe" class="size-5 opacity-80 group-hover:opacity-100 transition-opacity" aria-hidden="true" />
                <span class="absolute -bottom-1 -right-2 uppercase font-black text-[8px] leading-none tracking-widest opacity-90 bg-base-100 rounded-[2px] px-0.5 border border-base-content/10">{currentLocale}</span>
            </div>
            <span class="font-medium text-sm sm:hidden">{langDict["label"] || __("Language")}</span>
        </div>
        <svg
            width="12px"
            height="12px"
            class="hidden size-2 fill-current opacity-60 sm:inline-block"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 2048 2048"
        >
            <path d="M1799 349l242 241-1017 1017L7 590l242-241 775 775 775-775z"></path>
        </svg>
    </div>
    <div
        tabindex="0"
        class="dropdown-content bg-base-200 text-base-content rounded-box bottom-full mb-2 sm:top-px sm:mt-16 max-h-[50vh] sm:max-h-[calc(100vh-12rem)] w-[calc(100vw-8rem)] sm:w-56 overflow-y-auto border-(length:--border) border-white/5 shadow-2xl outline-(length:--border) outline-black/5 z-50"
    >
        <ul class="menu menu-sm gap-1 p-2">
            <li class="menu-title px-2 py-1 text-xs font-medium opacity-70">
                {langDict["label"] || __("Language")}
            </li>
            {
                locales.map((locale) => (
                    <li>
                        <a
                            href={getRelativeLocaleUrl(locale, currentPath)}
                            data-locale-link={locale}
                            class:list={[
                                "justify-start gap-3 px-2 font-normal hover:bg-base-content/10",
                                {
                                    "bg-base-content/10!":
                                        currentLocale === locale,
                                },
                            ]}
                        >
                            <div class="w-full truncate text-start">
                                <span class="font-medium">
                                    {nativeNames[
                                        locale as keyof typeof nativeNames
                                    ] || locale}
                                </span>
                                <span class="text-xs opacity-70 ml-2">
                                    ({langDict[locale] || locale})
                                </span>
                            </div>
                            {currentLocale === locale && (
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="16"
                                    height="16"
                                    viewBox="0 0 24 24"
                                    fill="currentColor"
                                    class="h-3 w-3 shrink-0 opacity-70"
                                >
                                    <path d="M20.285 2l-11.285 11.567-5.286-5.011-3.714 3.716 9 8.728 15-15.285z" />
                                </svg>
                            )}
                        </a>
                    </li>
                ))
            }
        </ul>
    </div>
</div>

<script is:inline>
    // Save user preference when they manually switch languages
    document.querySelectorAll('[data-locale-link]').forEach(link => {
        link.addEventListener('click', () => {
            const locale = link.getAttribute('data-locale-link');
            if (locale) {
                localStorage.setItem('preferred-locale', locale);
            }
        });
    });
</script>
