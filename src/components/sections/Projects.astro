---
import { getTranslations } from "@i18n";
import { Image } from "astro:assets";
import { ExternalLink, Github } from "lucide-react";
import type { Project } from "../../types";

interface Props {
    projects: (Project & { displayDescription: string })[];
    lang: string;
}

const { projects, lang } = Astro.props;
const t = (await getTranslations(lang, "portfolio")) as Record<string, any>;
---

<section id="projects" class="py-32 px-6 lg:px-20 relative z-10">
    <div class="max-w-7xl mx-auto">
        <div class="flex flex-col md:flex-row justify-between items-end mb-16">
            <div>
                <h2
                    class="text-xs font-bold text-primary tracking-widest uppercase mb-2"
                >
                    // {t.projects.title}
                </h2>
                <h3 class="text-4xl md:text-6xl font-bold text-base-content">
                    {t.projects.heading}
                </h3>
            </div>
            <div
                class="hidden md:block w-32 h-1 bg-base-content/10 rounded-full mt-6 md:mt-0"
            >
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {
                projects.map((project, index) => {
                    const isFeatured = index === 0 || index === 3;
                    return (
                        <div
                            class:list={[
                                "card image-full group overflow-hidden bg-base-100 shadow-xl",
                                isFeatured ? "md:col-span-2" : "md:col-span-1",
                                "h-[400px]",
                            ]}
                        >
                            <figure>
                                <Image
                                    src={project.imageUrl}
                                    alt={project.title}
                                    inferSize={true}
                                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 opacity-60 group-hover:opacity-40"
                                />
                            </figure>

                            <div class="card-body justify-end p-8 transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
                                <div class="flex gap-2 mb-4 flex-wrap">
                                    {project.technologies
                                        .slice(0, 3)
                                        .map((tech) => (
                                            <span class="badge badge-outline badge-sm uppercase text-[10px] tracking-wider border-base-content/20 bg-base-100/20 backdrop-blur-sm text-base-content">
                                                {tech}
                                            </span>
                                        ))}
                                </div>

                                <h3 class="card-title text-3xl font-bold text-white mb-2 shadow-sm">
                                    {project.title}
                                </h3>
                                <p class="text-white/80 text-sm line-clamp-2 mb-6 group-hover:text-white transition-colors grow-0">
                                    {project.displayDescription}
                                </p>

                                <div class="card-actions flex gap-4 opacity-0 group-hover:opacity-100 transition-opacity duration-500 delay-100 mt-auto">
                                    <a
                                        href={`/${lang}/projects/${project.slug}`}
                                        class="btn btn-primary btn-sm rounded-full text-xs"
                                        aria-label={`Read Case Study for ${project.title}`}
                                    >
                                        Case Study
                                    </a>
                                    {project.demoUrl && (
                                        <a
                                            href={project.demoUrl}
                                            target="_blank"
                                            rel="noreferrer"
                                            class="btn btn-outline btn-sm rounded-full text-xs border-white/20 text-white hover:bg-white/10"
                                            aria-label={`Demo of ${project.title}`}
                                        >
                                            <ExternalLink className="size-4" />
                                            {t.projects.viewProject}
                                        </a>
                                    )}
                                    {project.repoUrl && (
                                        <a
                                            href={project.repoUrl}
                                            target="_blank"
                                            rel="noreferrer"
                                            class="btn btn-ghost btn-sm rounded-full text-xs text-white hover:bg-base-content/20"
                                            aria-label={`Source Code of ${project.title}`}
                                        >
                                            <Github className="size-4" />
                                            {t.projects.code}
                                        </a>
                                    )}
                                </div>
                            </div>
                        </div>
                    );
                })
            }
        </div>
    </div>
</section>
