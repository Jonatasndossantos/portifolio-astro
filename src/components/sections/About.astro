---
import { getTranslations, useTranslator } from "@i18n";
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import type { CuratedProfile } from "../../types";

interface Props {
    skills: {
        id: string;
        name: string;
        category: string;
        currentRelevance: number;
    }[];
    profile: CuratedProfile;
    mode: string;
    lang: string;
}

const { skills, profile, mode, lang } = Astro.props;
const t = (await getTranslations(lang, "portfolio")) as Record<string, any>;
const __ = await useTranslator(lang);
---

<section id="about" class="py-32 px-6 lg:px-20 relative z-10">
    <div
        class="max-w-7xl mx-auto flex flex-col md:flex-row gap-20 items-center"
    >
        <!-- Profile Image Ring -->
        <div class="w-full md:w-1/3 flex justify-center">
            <div class="relative w-64 h-64 md:w-80 md:h-80">
                <div
                    class="absolute inset-0 rounded-full border border-base-content/10 animate-[spin_10s_linear_infinite]"
                >
                </div>
                <div
                    class="absolute -inset-4 rounded-full border border-primary/20 animate-[spin_15s_linear_infinite_reverse]"
                >
                </div>
                <div
                    class="w-full h-full rounded-full overflow-hidden border-2 border-base-content/10 shadow-[0_0_50px_rgba(var(--bg-primary),0.1)] grayscale hover:grayscale-0 transition-all duration-500"
                >
                    <Image
                        src="https://github.com/Jonatasndossantos/Jonatasndossantos/blob/main/src/perfil.jfif?raw=true"
                        alt={__("Profile")}
                        width={320}
                        height={320}
                        class="w-full h-full object-cover"
                    />
                </div>
            </div>
        </div>

        <!-- Text & Skills -->
        <div class="w-full md:w-2/3">
            <h2
                class="text-xs font-bold text-primary tracking-widest uppercase mb-4"
            >
                // {t.about.title}
            </h2>
            <h3
                class="text-3xl md:text-5xl font-bold text-base-content mb-6 leading-tight"
                set:html={t.about.heading}
            />

            <p class="text-base-content/70 text-lg leading-relaxed mb-12">
                {profile.bio}
            </p>

            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                {
                    skills.slice(0, 8).map((skill) => (
                        <div class="glass flex items-center gap-3 p-4 rounded-xl hover:bg-base-content/5 transition-colors group cursor-default border border-base-content/10">
                            <div class="text-primary group-hover:text-base-content transition-colors">
                                {(() => {
                                    switch (skill.category) {
                                        case "framework":
                                            return <Icon name="lucide:globe" class="size-6" />;
                                        case "language":
                                            return <Icon name="lucide:code" class="size-6" />;
                                        case "tool":
                                            return (
                                                <Icon name="lucide:terminal" class="size-6" />
                                            );
                                        case "data":
                                            return (
                                                <Icon name="lucide:database" class="size-6" />
                                            );
                                        case "cloud":
                                            return <Icon name="lucide:cloud" class="size-6" />;
                                        default:
                                            return <Icon name="lucide:cpu" class="size-6" />;
                                    }
                                })()}
                            </div>
                            <span class="text-sm font-medium text-base-content/80 group-hover:text-base-content">
                                {skill.name}
                            </span>
                        </div>
                    ))
                }
            </div>
        </div>
    </div>
</section>
