---
import { getTranslations } from "@i18n";
import {
    Send,
    Linkedin,
    Github,
    Mail,
    CheckCircle,
    AlertCircle,
} from "lucide-react";
import type { CuratedProfile } from "../../types";

interface Props {
    profile: CuratedProfile;
    lang: string;
}

const { profile, lang } = Astro.props;
const t = (await getTranslations(lang, "portfolio")) as Record<string, any>;
---

<section id="contact" class="py-32 px-6 lg:px-20 relative z-10 overflow-hidden">
    <!-- Decorative Blob -->
    <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-primary/10 blur-[120px] rounded-full pointer-events-none"
    >
    </div>

    <div class="max-w-5xl mx-auto relative z-10">
        <div class="grid md:grid-cols-2 gap-16">
            <!-- Contact Info -->
            <div>
                <h2
                    class="text-xs font-bold text-primary tracking-widest uppercase mb-4"
                >
                    // {t.contact.title}
                </h2>
                <h3
                    class="text-5xl md:text-6xl font-bold text-base-content mb-6"
                >
                    {t.contact.heading}
                </h3>
                <p class="text-base-content/70 text-lg mb-8">
                    {t.contact.desc}
                </p>

                <div class="flex flex-col gap-4">
                    <a
                        href={`mailto:${profile.socials.email}`}
                        class="flex items-center gap-4 p-4 glass rounded-xl hover:bg-base-content/5 transition-all group border border-base-content/10"
                        aria-label="Email Me"
                    >
                        <div
                            class="p-3 bg-base-100 rounded-full text-primary group-hover:scale-110 transition-transform"
                        >
                            <Mail size={24} />
                        </div>
                        <div>
                            <div
                                class="text-xs text-base-content/50 uppercase tracking-wider"
                            >
                                {t.contact.email}
                            </div>
                            <div
                                class="text-base-content font-mono font-medium"
                            >
                                {profile.socials.email}
                            </div>
                        </div>
                    </a>
                    <a
                        href={profile.socials.linkedin}
                        target="_blank"
                        rel="noreferrer"
                        class="flex items-center gap-4 p-4 glass rounded-xl hover:bg-base-content/5 transition-all group border border-base-content/10"
                        aria-label="My LinkedIn"
                    >
                        <div
                            class="p-3 bg-base-100 rounded-full text-primary group-hover:scale-110 transition-transform"
                        >
                            <Linkedin size={24} />
                        </div>
                        <div>
                            <div
                                class="text-xs text-base-content/50 uppercase tracking-wider"
                            >
                                LinkedIn
                            </div>
                            <div
                                class="text-base-content font-mono font-medium"
                            >
                                /in/jonatasndossantos
                            </div>
                        </div>
                    </a>
                    <a
                        href={profile.socials.github}
                        target="_blank"
                        rel="noreferrer"
                        class="flex items-center gap-4 p-4 glass rounded-xl hover:bg-base-content/5 transition-all group border border-base-content/10"
                        aria-label="My GitHub"
                    >
                        <div
                            class="p-3 bg-base-100 rounded-full text-primary group-hover:scale-110 transition-transform"
                        >
                            <Github size={24} />
                        </div>
                        <div>
                            <div
                                class="text-xs text-base-content/50 uppercase tracking-wider"
                            >
                                GitHub
                            </div>
                            <div
                                class="text-base-content font-mono font-medium"
                            >
                                jonatasndossantos
                            </div>
                        </div>
                    </a>
                </div>
            </div>

            <!-- Contact Form Component (Native Vanilla JS) -->
            <form
                id="contact-form"
                class="glass p-8 rounded-3xl border border-base-content/10 space-y-6 relative overflow-hidden bg-base-200/50 shadow-2xl"
            >
                <div
                    id="form-success"
                    class="hidden absolute inset-0 bg-base-200/95 backdrop-blur-md z-20 flex-col items-center justify-center text-center p-8 animate-fade-in"
                >
                    <CheckCircle size={64} className="text-success mb-4" />
                    <h4 class="text-2xl font-bold text-base-content mb-2">
                        {t.contact.messageSent}
                    </h4>
                    <p class="text-base-content/70">
                        Thanks for reaching out! I'll get back to you soon.
                    </p>
                    <button
                        type="button"
                        id="btn-reset-form"
                        class="btn btn-outline btn-sm mt-6 rounded-full uppercase tracking-widest"
                    >
                        {t.contact.sendAnother}
                    </button>
                </div>

                <div>
                    <label
                        for="name"
                        class="block text-xs uppercase font-bold text-base-content/60 mb-2"
                        >{t.contact.nameLabel}</label
                    >
                    <input
                        required
                        name="name"
                        id="name"
                        type="text"
                        class="input input-bordered w-full bg-base-100 focus:input-primary"
                        placeholder="John Doe"
                    />
                </div>
                <div>
                    <label
                        for="email"
                        class="block text-xs uppercase font-bold text-base-content/60 mb-2"
                        >{t.contact.emailLabel}</label
                    >
                    <input
                        required
                        name="email"
                        id="email"
                        type="email"
                        class="input input-bordered w-full bg-base-100 focus:input-primary"
                        placeholder="john@example.com"
                    />
                </div>
                <div>
                    <label
                        for="message"
                        class="block text-xs uppercase font-bold text-base-content/60 mb-2"
                        >{t.contact.messageLabel}</label
                    >
                    <textarea
                        required
                        name="message"
                        id="message"
                        class="textarea textarea-bordered w-full h-32 bg-base-100 focus:textarea-primary resize-none"
                        placeholder="Tell me about your project..."></textarea>
                </div>

                <div
                    id="form-error"
                    class="hidden items-center gap-2 text-error text-sm bg-error/10 p-3 rounded-lg border border-error/20"
                >
                    <AlertCircle size={20} />
                    <span>{t.contact.somethingWrong}</span>
                </div>

                <button
                    id="submit-button"
                    type="submit"
                    class="btn btn-primary w-full tracking-widest uppercase group"
                >
                    <span id="submit-text">{t.contact.sendMessage}</span>
                    <Send
                        className="size-4 group-hover:translate-x-1 transition-transform"
                    />
                </button>
            </form>
        </div>
    </div>
</section>

<script>
    // Handles form submission via Vanilla JS to avoid React Hydration.
    // Encapsulate inside an event listener to support Astro View Transitions if enabled.
    document.addEventListener("astro:page-load", () => {
        const form = document.getElementById("contact-form") as HTMLFormElement;
        const successOverlay = document.getElementById("form-success");
        const errorAlert = document.getElementById("form-error");
        const submitBtn = document.getElementById(
            "submit-button",
        ) as HTMLButtonElement;
        const submitText = document.getElementById("submit-text");
        const resetBtn = document.getElementById("btn-reset-form");

        if (!form) return;

        form.addEventListener("submit", async (e) => {
            e.preventDefault();

            // Disable button during flight
            submitBtn.disabled = true;
            const originalText = submitText!.innerText;
            submitText!.innerText = "SENDING...";
            errorAlert!.classList.add("hidden");

            const formData = new FormData(form);
            const FORMSPREE_ID = "mrbnjqlz";

            try {
                const response = await fetch(
                    `https://formspree.io/f/${FORMSPREE_ID}`,
                    {
                        method: "POST",
                        body: formData,
                        headers: { Accept: "application/json" },
                    },
                );

                if (response.ok) {
                    form.reset();
                    successOverlay!.classList.remove("hidden");
                    successOverlay!.classList.add("flex");
                } else {
                    errorAlert!.classList.remove("hidden");
                    errorAlert!.classList.add("flex");
                }
            } catch (err) {
                errorAlert!.classList.remove("hidden");
                errorAlert!.classList.add("flex");
            } finally {
                submitBtn.disabled = false;
                submitText!.innerText = originalText;
            }
        });

        // Reset the form view so users can send another message
        resetBtn?.addEventListener("click", () => {
            successOverlay!.classList.add("hidden");
            successOverlay!.classList.remove("flex");
        });
    });
</script>
